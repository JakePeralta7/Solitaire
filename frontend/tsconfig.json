{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM"],
